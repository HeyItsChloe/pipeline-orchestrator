{
  "name": "@heyitschloe/pipeline-orchestrator",
  "version": "0.1.0",
  "description": "A generic, skill-driven GitHub App pipeline engine. Self-hosted — clone and run standalone, or import as a library and register your own pipeline handlers.",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "generate:site": "node scripts/generate-site.mjs",
    "generate:overview": "node scripts/generate-overview.mjs",
    "generate:changelog": "node scripts/generate-changelog.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.3.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HeyItsChloe/pipeline-orchestrator.git"
  }
}
