# Copy to .env and fill in — never commit the real .env file.

# GitHub App (register your own at github.com/settings/apps — this is a
# separate App from anyone else's self-hosted instance).
GH_APP_ID=
GH_APP_PRIVATE_KEY=
GH_WEBHOOK_SECRET=
# The installation ID covering whichever account/org owns the repos this
# instance manages (Settings -> Installed GitHub Apps -> your app -> URL
# has the installation ID in it).
GH_APP_INSTALLATION_ID=

# Shared-secret auth for /trigger, /webhook/mcp.
ORCHESTRATOR_SHARED_SECRET=

# Allowlisted GitHub usernames whose @mention comments are honored.
ALLOWED_MENTION_AUTHORS=

# Path to this deployment's own pipelines.yaml — private data, not part of
# this package. Point it at wherever you keep your registry (a mounted
# path, a path inside your own control repo checkout, etc).
REGISTRY_PATH=

# Optional — only needed to enable the scaffold_pipeline tool, which writes
# new skill files / registry entries / caller workflows to a control repo.
CONTROL_REPO_OWNER=
CONTROL_REPO_NAME=
CONTROL_REPO_BRANCH=main

PORT=3000
